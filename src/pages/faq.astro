---
import Base from '../layouts/Base.astro';
---
<Base title="F.A.Q · Soleia Expérience" active="faq">
  <!-- ===================== DÉCORS RÉUTILISABLES (définis une fois, réutilisés via <use>) ===================== -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
    <defs>
      <!-- ✺ SOLEIL DESSINÉ-MAIN : disque plein orangé + rayons ONDULÉS organiques (16 rayons). -->
      <g id="soleiaSunDoodle">
        <circle cx="50" cy="50" r="20" fill="#f8742f"/>
        <circle cx="50" cy="50" r="20" fill="#f4b63e" opacity="0.18"/>
        <g fill="none" stroke="#f8742f" stroke-width="4.4" stroke-linecap="round">
          <path d="M50 28 q3 -6 -0.6 -13"/>
          <path d="M58.6 29.4 q5 -4 5.4 -10.4"/>
          <path d="M66.3 33.5 q6.4 -3.4 12.8 -5.2"/>
          <path d="M70.9 40.2 q6.6 -1.4 13.6 -1.4"/>
          <path d="M72.4 50 q7.4 0.6 13.6 -1.4"/>
          <path d="M70.9 59.8 q7 1.6 12.4 6.2"/>
          <path d="M66.3 66.5 q6.2 3.2 10.6 8.8"/>
          <path d="M58.6 70.6 q4.8 5 5 12.2"/>
          <path d="M50 72 q-2.8 6.4 0.6 13.4"/>
          <path d="M41.4 70.6 q-5 4.6 -5.4 11.4"/>
          <path d="M33.7 66.5 q-6.2 3.2 -12.4 4.4"/>
          <path d="M29.1 59.8 q-6.8 1.6 -13.4 0.4"/>
          <path d="M27.6 50 q-7.6 -0.6 -14.4 1.2"/>
          <path d="M29.1 40.2 q-6.8 -1.6 -11.8 -6.6"/>
          <path d="M33.7 33.5 q-6 -3.4 -9.4 -9"/>
          <path d="M41.4 29.4 q-4.6 -4.6 -4.2 -11.2"/>
        </g>
      </g>

      <!-- ✿ FLEUR RÉTRO/GROOVY : 5 pétales larges, cœur jaune doré arrondi. Couleur pilotée par currentColor. -->
      <g id="soleiaFlowerRetro">
        <g fill="currentColor">
          <path d="M50 12
                   c 9 0 15 7 14.5 15
                   c -0.4 6 -4 9.5 -8 12
                   c -2.5 1.6 -4.6 3 -6.5 3
                   c -1.9 0 -4 -1.4 -6.5 -3
                   c -4 -2.5 -7.6 -6 -8 -12
                   c -0.5 -8 5 -15 14.5 -15 Z"/>
          <path d="M86.1 38.2
                   c 2.8 8.6 -1.1 16.3 -8.5 19.4
                   c -5.6 2.3 -10.1 0.6 -13.9 -1.9
                   c -2.4 -1.6 -4.5 -2.9 -5.4 -4.6
                   c -0.9 -1.8 -0.7 -4.3 -0.1 -7.2
                   c 0.9 -4.6 3 -9.3 8.6 -11.6
                   c 7.6 -3.1 16 0 19.2 5.9 Z"/>
          <path d="M72.3 80.9
                   c -7.3 5.3 -15.9 4.2 -20.4 -2.3
                   c -3.5 -4.9 -2.7 -9.6 -1.2 -13.9
                   c 0.9 -2.7 1.6 -5.1 3.1 -6.2
                   c 1.5 -1.1 4 -1.3 6.9 -1.3
                   c 4.7 0 9.8 1.1 13.3 6
                   c 4.5 6.5 5 15.1 -1.7 19.9
                   l 0 -2.2 Z"/>
          <path d="M27.7 80.9
                   c -6.7 -4.8 -6.2 -13.4 -1.7 -19.9
                   c 3.5 -4.9 8.6 -6 13.3 -6
                   c 2.9 0 5.4 0.2 6.9 1.3
                   c 1.5 1.1 2.2 3.5 3.1 6.2
                   c 1.5 4.3 2.3 9 -1.2 13.9
                   c -4.5 6.5 -13.1 7.6 -20.4 2.3 Z"/>
          <path d="M13.9 38.2
                   c 3.2 -5.9 11.6 -9 19.2 -5.9
                   c 5.6 2.3 7.7 7 8.6 11.6
                   c 0.6 2.9 0.8 5.4 -0.1 7.2
                   c -0.9 1.7 -3 3 -5.4 4.6
                   c -3.8 2.5 -8.3 4.2 -13.9 1.9
                   c -7.4 -3.1 -11.3 -10.8 -8.5 -19.4 Z"/>
        </g>
        <rect x="42" y="42" width="16" height="16" rx="6.4" fill="#f4b63e"/>
      </g>
    </defs>
  </svg>

  <!-- ===================== CALQUE DÉCOR PLEINE PAGE (fleurs + soleils déplaçables) ===================== -->
  <div class="deco-layer" aria-hidden="true">
    <!-- ░░ Zone titre (haut de page) ░░ -->
    <span class="deco-item is-float" data-deco-id="deco-1"  style="top:5%;    left:8%;   --rot:-10deg; --s:0.74; --dur:8s;  --delay:-1s;  color:var(--rose);"><svg viewBox="0 0 100 100"><use href="#soleiaFlowerRetro"/></svg></span>
    <span class="deco-item is-float" data-deco-id="deco-2"  style="top:3.6%;  right:9%;  --rot:8deg;   --s:0.98; --dur:10s; --delay:-3s;"><svg viewBox="0 0 100 100"><use href="#soleiaSunDoodle"/></svg></span>
    <span class="deco-item is-float hide-small" data-deco-id="deco-3"  style="top:11%;   left:22%;  --rot:14deg;  --s:0.54; --dur:9s;  --delay:-2s;  color:var(--orange);"><svg viewBox="0 0 100 100"><use href="#soleiaFlowerRetro"/></svg></span>

    <!-- ░░ Marges latérales (le long des questions) ░░ -->
    <span class="deco-item is-float hide-mobile" data-deco-id="deco-4"  style="top:30%;   right:3%;  --rot:-6deg;  --s:0.62; --dur:11s; --delay:-4s;  color:var(--rose-doux);"><svg viewBox="0 0 100 100"><use href="#soleiaFlowerRetro"/></svg></span>
    <span class="deco-item is-float hide-mobile" data-deco-id="deco-5"  style="top:46%;   left:2.5%; --rot:6deg;   --s:0.6;  --dur:10s; --delay:-2.5s;"><svg viewBox="0 0 100 100"><use href="#soleiaSunDoodle"/></svg></span>
    <span class="deco-item is-float hide-mobile" data-deco-id="deco-6"  style="top:62%;   right:3%;  --rot:11deg;  --s:0.66; --dur:9s;  --delay:-1.5s; color:var(--rose);"><svg viewBox="0 0 100 100"><use href="#soleiaFlowerRetro"/></svg></span>
    <span class="deco-item is-float hide-mobile" data-deco-id="deco-7"  style="top:76%;   left:3%;   --rot:-9deg;  --s:0.6;  --dur:11s; --delay:-3.5s; color:var(--orange);"><svg viewBox="0 0 100 100"><use href="#soleiaFlowerRetro"/></svg></span>

    <!-- ░░ Bas de page ░░ -->
    <span class="deco-item is-float" data-deco-id="deco-9"  style="top:92%;   left:10%;  --rot:10deg;  --s:0.66; --dur:10s; --delay:-3.5s; color:var(--orange);"><svg viewBox="0 0 100 100"><use href="#soleiaFlowerRetro"/></svg></span>
    <span class="deco-item is-float" data-deco-id="deco-10" style="top:93%;   right:11%; --rot:-8deg;  --s:0.62; --dur:9s;  --delay:-2s;"><svg viewBox="0 0 100 100"><use href="#soleiaSunDoodle"/></svg></span>
  </div>

  <!-- ===================== CONTENU « FAQ » ===================== -->
  <main class="page">

    <!-- ===== GRAND TITRE de la page ===== -->
    <section class="hero reveal" aria-labelledby="faq-title">
      <h1 class="hero__title" id="faq-title">FAQ</h1>
      <span class="hero__rule" aria-hidden="true"></span>
    </section>

    <!-- ===== ONGLETS PAR CATÉGORIE (pilules) ===== -->
    <div class="tabs reveal" role="tablist" aria-label="Catégories de questions">
      <button class="tab" role="tab" id="tab-1" aria-controls="panel-1" aria-selected="true">
        <span class="tab__dot" aria-hidden="true"></span>Réservations d’ateliers
      </button>
      <button class="tab" role="tab" id="tab-3" aria-controls="panel-3" aria-selected="false" tabindex="-1">
        <span class="tab__dot" aria-hidden="true"></span>Déroulement des ateliers
      </button>
      <button class="tab" role="tab" id="tab-2" aria-controls="panel-2" aria-selected="false" tabindex="-1">
        <span class="tab__dot" aria-hidden="true"></span>Bons cadeaux
      </button>
      <button class="tab" role="tab" id="tab-4" aria-controls="panel-4" aria-selected="false" tabindex="-1">
        <span class="tab__dot" aria-hidden="true"></span>Annulation et modification
      </button>
    </div>

    <!-- ===== PANNEAU 1 — Réservations d’ateliers ===== -->
    <section class="panel is-shown" id="panel-1" role="tabpanel" aria-labelledby="tab-1" tabindex="0">
      <header class="panel__head">
        <h2 class="panel__title">Réservations d’ateliers</h2>
      </header>
      <div class="accordion">

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Comment réserver un atelier&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">La réservation se fait directement sur notre site. Il suffit de cliquer sur le bouton de réservation qui vous redirige vers la page des ateliers pour choisir votre expérience et finaliser votre inscription.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Comment savoir si ma réservation est confirmée&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Une fois votre réservation effectuée, vous recevez un mail de confirmation envoyé directement par nos soins. Pensez à vérifier vos spams si besoin.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Les ateliers ont-ils un nombre de places limité&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Oui, chaque atelier est limité à 10 personnes maximum afin de garantir une expérience intime, conviviale et de qualité.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Puis-je offrir une place à quelqu’un&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Oui 🤍 Pour offrir une place à un atelier, vous pouvez passer par nos bons cadeaux, spécialement pensés pour faire plaisir et offrir une expérience Soleia à vos proches.</p>
          </div></div>
        </div>

      </div>
    </section>

    <!-- ===== PANNEAU 2 — Bons cadeaux ===== -->
    <section class="panel" id="panel-2" role="tabpanel" aria-labelledby="tab-2" tabindex="0" hidden>
      <header class="panel__head">
        <h2 class="panel__title">Bons cadeaux</h2>
      </header>
      <div class="accordion">

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Comment acheter un bon cadeau&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Les bons cadeaux sont disponibles directement sur notre site. Une fois la commande validée, ils sont envoyés sous format digital sous 1 à 3 jours. Vous pouvez ensuite les imprimer si vous souhaitez les offrir en main propre.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Quelle est la durée de validité d’un bon cadeau&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Les bons cadeaux sont valables pendant 1 an à partir de la date d’achat.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Le bon cadeau est-il valable sur tous les ateliers&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Oui 🤍 Les bons cadeaux peuvent être utilisés sur l’ensemble des ateliers Soleia. Il est également possible de choisir un atelier précis lors de l’achat.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Puis-je personnaliser mon bon cadeau&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Oui ✨ Il est possible d’ajouter un message personnalisé afin de rendre le cadeau encore plus unique et personnel.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Comment utiliser un bon cadeau&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Pour réserver un atelier avec un bon cadeau, il suffit de nous envoyer un mail avec le numéro du bon cadeau ainsi que les informations de réservation.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Les bons cadeaux sont-ils remboursables&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Les bons cadeaux ne sont pas remboursables.</p>
          </div></div>
        </div>

      </div>
    </section>

    <!-- ===== PANNEAU 3 — Déroulement des ateliers ===== -->
    <section class="panel" id="panel-3" role="tabpanel" aria-labelledby="tab-3" tabindex="0" hidden>
      <header class="panel__head">
        <h2 class="panel__title">Déroulement des ateliers</h2>
      </header>
      <div class="accordion">

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Puis-je venir seule&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Oui 🤍 Les ateliers sont ouverts à toutes, que vous veniez seule ou accompagnée. Beaucoup de participantes viennent seules et repartent souvent après de belles rencontres.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Faut-il avoir de l’expérience&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Pas du tout ✨ Les ateliers Soleia sont accessibles à toutes, même aux débutantes. L’objectif est de découvrir, expérimenter et surtout de profiter du moment sans pression.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Que dois-je apporter le jour de l’atelier&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Rien de particulier. Tout le matériel nécessaire est fourni sur place. Il suffit de venir comme vous êtes, prête à profiter de l’expérience.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Y a-t-il un âge minimum pour participer&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Oui 🤍 Les ateliers sont accessibles à partir de 18 ans.</p>
          </div></div>
        </div>

      </div>
    </section>

    <!-- ===== PANNEAU 4 — Annulation et modification ===== -->
    <section class="panel" id="panel-4" role="tabpanel" aria-labelledby="tab-4" tabindex="0" hidden>
      <header class="panel__head">
        <h2 class="panel__title">Annulation et modification</h2>
      </header>
      <div class="accordion">

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Puis-je annuler ma réservation&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Oui 🤍 Les réservations peuvent être annulées, mais elles ne sont pas remboursables. En cas d’empêchement, vous pouvez néanmoins céder votre place à une autre personne, à condition de nous en informer par mail.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Puis-je céder ma place à quelqu’un d’autre&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Oui ✨ Vous pouvez transmettre votre place à une autre personne. Il suffit de nous prévenir en amont par mail avec les informations de la personne qui vous remplace.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Que se passe-t-il si Soleia doit annuler un atelier&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Dans le cas exceptionnel où un atelier serait annulé par nous, vous aurez le choix entre un remboursement intégral ou un avoir valable sur un prochain atelier.</p>
          </div></div>
        </div>

        <div class="qa">
          <button class="qa__btn" aria-expanded="false">
            <span class="qa__q">Comment suis-je informée d’un changement&#8239;?</span>
            <span class="qa__sign" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M5 12h14"/><path class="bar-v" d="M12 5v14"/></svg>
            </span>
          </button>
          <div class="qa__panel"><div class="qa__panel-inner">
            <p class="qa__answer">Toute modification ou annulation vous sera communiquée directement par mail dans les plus brefs délais afin de vous tenir informée sereinement.</p>
          </div></div>
        </div>

      </div>
    </section>

    <!-- ===== petit bloc « encore une question ? » ===== -->
    <section class="stay reveal" aria-label="Encore une question">
      <span class="stay__sun" aria-hidden="true"><svg viewBox="0 0 100 100"><use href="#soleiaSunDoodle"/></svg></span>
      <p class="stay__title">Tu ne trouves pas&#8239;? <span class="grad">Écris-nous, on adore ça&#8239;!</span></p>
      <a class="stay__mail" href="mailto:soleiaexperience@gmail.com">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3"/><path d="m4 7 8 5.5L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Nous écrire
      </a>
    </section>

  </main>

  <style is:global>
    /* ============================================================
       CONTENU « FAQ » — grand titre + onglets par catégorie
       ============================================================ */
    .page {
      position: relative;
      z-index: 2;
      max-width: 880px;
      margin: 0 auto;
      padding: clamp(1.4rem, 4vw, 3rem) clamp(1.4rem, 5vw, 3rem) clamp(3rem, 7vw, 6rem);
    }

    /* ---- GRAND TITRE de la page (façon hero) ---- */
    .hero {
      text-align: center;
      padding: clamp(3rem, 9vh, 6.5rem) 0 clamp(1.6rem, 4.5vh, 3rem);
    }
    .hero__title {
      font-family: "Fraunces", Georgia, serif;
      font-style: italic;                 /* LÉGÈREMENT italique pour l'élégance */
      font-weight: 420;
      font-size: clamp(3.2rem, 10vw, 6.4rem);
      line-height: 1.0;
      letter-spacing: -0.02em;
      margin: 0;
      color: var(--ink);
      font-variation-settings: "opsz" 144;
      background: linear-gradient(96deg, var(--rose) 0%, var(--orange) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    .hero__subtitle {
      font-family: "Space Grotesk", system-ui, sans-serif;
      font-weight: 400;
      font-size: clamp(1.02rem, 2vw, 1.25rem);
      line-height: 1.5;
      letter-spacing: 0.005em;
      color: var(--ink-soft);
      margin: clamp(0.9rem, 2.4vh, 1.4rem) auto 0;
      max-width: 40ch;
    }
    .hero__rule {
      display: block;
      width: clamp(56px, 8vw, 96px);
      height: 4px;
      margin: clamp(1.3rem, 3vh, 2rem) auto 0;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--rose), var(--orange));
      opacity: 0.9;
    }

    /* ============================================================
       ONGLETS PAR CATÉGORIE (pilules) — une seule catégorie visible
       ============================================================ */
    .tabs {
      display: flex;
      flex-wrap: nowrap;                  /* les 4 onglets sur une seule ligne */
      justify-content: center;
      gap: clamp(0.26rem, 0.6vw, 0.45rem);
      max-width: 100%;
      margin: 0 auto clamp(2rem, 5vh, 3.2rem);
      padding: 0.5rem 0.2rem 0.6rem;
    }
    .tab {
      font-family: "Bricolage Grotesque", "Space Grotesk", sans-serif;
      font-weight: 700;
      font-size: clamp(0.64rem, 1.3vw, 0.94rem);
      letter-spacing: 0.002em;
      color: var(--ink);
      white-space: nowrap;
      flex: 0 0 auto;
      background: var(--glass-strong);
      -webkit-backdrop-filter: blur(8px);
      backdrop-filter: blur(8px);
      border: 1.5px solid rgba(255, 250, 246, 0.8);
      box-shadow: 0 8px 22px rgba(248, 116, 47, 0.08), inset 0 0 0 1px rgba(248, 116, 47, 0.05);
      border-radius: 999px;
      padding: 0.5em 0.9em;               /* en « em » : se réduit avec la police sur petits écrans */
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.28s ease, color 0.25s ease, background 0.3s ease, border-color 0.25s ease;
    }
    .tab__dot {
      display: none;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--rose), var(--orange));
      opacity: 0.55;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .tab:hover {
      transform: translateY(-2px);
      color: var(--orange);
      border-color: var(--rose);
      box-shadow: 0 12px 26px rgba(251, 107, 166, 0.18);
    }
    .tab[aria-selected="true"] {
      color: var(--orange);
      background: var(--glass-strong);
      border-color: var(--rose);
      box-shadow: 0 10px 24px rgba(248, 116, 47, 0.14);
    }
    .tab[aria-selected="true"] .tab__dot {
      background: var(--creme);
      opacity: 1;
      transform: scale(1.1);
    }

    /* ---- PANNEAU d'une catégorie : titre de catégorie + accordéons ---- */
    .panel { display: none; }
    .panel.is-shown { display: block; animation: panelIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) both; }
    @keyframes panelIn {
      0%   { opacity: 0; transform: translateY(14px); }
      100% { opacity: 1; transform: none; }
    }

    .panel__head {
      text-align: center;
      margin: 0 0 clamp(1.4rem, 3.5vh, 2.2rem);
    }
    .panel__kicker {
      display: inline-block;
      font-family: "League Spartan", sans-serif;
      font-weight: 700;
      font-size: 0.66rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--orange);
      margin: 0 0 0.5rem;
    }
    .panel__title {
      font-family: "Fraunces", Georgia, serif;
      font-weight: 480;
      font-size: clamp(1.55rem, 3.6vw, 2.3rem);
      line-height: 1.12;
      letter-spacing: -0.015em;
      color: var(--ink);
      margin: 0;
      font-variation-settings: "opsz" 110;
    }

    /* ---- LISTE D'ACCORDÉONS ---- */
    .accordion {
      display: flex;
      flex-direction: column;
      gap: clamp(0.8rem, 1.8vh, 1.1rem);
    }

    .qa {
      border-radius: 22px;
      background: var(--glass);
      -webkit-backdrop-filter: blur(7px);
      backdrop-filter: blur(7px);
      border: 1.5px solid rgba(255, 250, 246, 0.7);
      box-shadow: 0 12px 32px rgba(248, 116, 47, 0.07), 0 4px 14px rgba(251, 107, 166, 0.06);
      overflow: hidden;
      transition: box-shadow 0.35s ease, border-color 0.3s ease;
    }
    .qa.is-open {
      box-shadow: 0 20px 44px rgba(248, 116, 47, 0.14), 0 8px 20px rgba(251, 107, 166, 0.12);
      border-color: rgba(251, 107, 166, 0.35);
    }

    /* la QUESTION = un bouton plein largeur, en GRAS */
    .qa__btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      text-align: left;
      background: transparent;
      border: none;
      cursor: pointer;
      padding: clamp(1.05rem, 2.2vw, 1.4rem) clamp(1.2rem, 2.8vw, 1.7rem);
      font-family: "Space Grotesk", system-ui, sans-serif;
      font-weight: 600;                  /* QUESTION EN GRAS */
      font-size: clamp(1.02rem, 1.6vw, 1.18rem);
      line-height: 1.4;
      letter-spacing: 0.002em;
      color: var(--ink);
      transition: color 0.25s ease;
    }
    .qa__btn:hover { color: var(--orange); }

    /* indicateur + / − (signe qui pivote) */
    .qa__sign {
      flex: 0 0 auto;
      width: clamp(30px, 4vw, 36px);
      height: clamp(30px, 4vw, 36px);
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: var(--orange);
      background: linear-gradient(135deg, rgba(251, 107, 166, 0.16), rgba(248, 116, 47, 0.16));
      box-shadow: inset 0 0 0 1.5px rgba(255, 250, 246, 0.7);
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s ease, color 0.25s ease;
    }
    .qa__sign svg { width: 48%; height: 48%; }
    /* la barre verticale du « + » disparaît à l'ouverture → devient « − » */
    .qa__sign .bar-v {
      transform-origin: center;
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
    }
    .qa.is-open .qa__sign {
      transform: rotate(180deg);
      color: var(--creme);
      background: linear-gradient(135deg, var(--rose), var(--orange));
    }
    .qa.is-open .qa__sign .bar-v { transform: scaleY(0); opacity: 0; }

    /* la RÉPONSE : zone qui se déplie en douceur (grid-rows animé) */
    .qa__panel {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .qa.is-open .qa__panel { grid-template-rows: 1fr; }
    .qa__panel-inner { overflow: hidden; }
    .qa__answer {
      margin: 0;
      padding: 0 clamp(1.2rem, 2.8vw, 1.7rem) clamp(1.15rem, 2.4vw, 1.5rem);
      font-family: "Space Grotesk", system-ui, sans-serif;
      font-weight: 300;                  /* RÉPONSE en typo plus FINE */
      font-size: clamp(0.95rem, 1.45vw, 1.06rem);
      line-height: 1.62;
      color: var(--ink-soft);
      max-width: 60ch;
    }
    .qa__answer .soon {
      font-style: italic;
      opacity: 0.92;
    }

    /* ===== petit bloc « encore une question ? » en bas (emplacement réservé) ===== */
    .stay {
      text-align: center;
      margin-top: clamp(3.4rem, 9vh, 6rem);
      padding: clamp(2rem, 5vw, 3rem) clamp(1.4rem, 4vw, 2.6rem);
      border-radius: 30px;
      background: var(--glass);
      -webkit-backdrop-filter: blur(7px);
      backdrop-filter: blur(7px);
      border: 1.5px solid rgba(255, 250, 246, 0.7);
      max-width: 620px;
      margin-left: auto;
      margin-right: auto;
      box-shadow: 0 18px 44px rgba(248, 116, 47, 0.10);
    }
    .stay__sun {
      width: clamp(38px, 5vw, 48px);
      height: clamp(38px, 5vw, 48px);
      margin: 0 auto clamp(0.7rem, 1.6vh, 1rem);
      display: block;
      filter: drop-shadow(0 4px 10px rgba(248, 116, 47, 0.18));
    }
    .stay__sun svg { width: 100%; height: 100%; display: block; overflow: visible; }
    .stay__title {
      font-family: "Fraunces", Georgia, serif;
      font-weight: 460;
      font-size: clamp(1.4rem, 3vw, 2rem);
      line-height: 1.18;
      letter-spacing: -0.015em;
      color: var(--ink);
      margin: 0;
      font-variation-settings: "opsz" 110;
    }
    .stay__title .grad {
      background: linear-gradient(96deg, var(--rose) 0%, var(--orange) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }
    .stay__mail {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      margin: clamp(1.1rem, 2.6vh, 1.5rem) auto 0;
      font-family: "Bricolage Grotesque", "Space Grotesk", sans-serif;
      font-weight: 700;
      font-size: clamp(0.96rem, 1.2vw, 1.05rem);
      color: var(--creme);
      text-decoration: none;
      padding: 0.7rem 1.5rem;
      border-radius: 999px;
      background: linear-gradient(96deg, var(--rose) 0%, var(--orange) 100%);
      box-shadow: 0 12px 26px rgba(248, 116, 47, 0.24), 0 4px 12px rgba(251, 107, 166, 0.18);
      transition: transform 0.26s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.26s ease;
    }
    .stay__mail svg { width: 17px; height: 17px; }
    .stay__mail:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 36px rgba(248, 116, 47, 0.32), 0 6px 16px rgba(251, 107, 166, 0.22);
    }

    /* ============ APPARITION AU DÉFILEMENT (avec repli : tout visible si pas de JS) ============ */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.22, 1, 0.36, 1); }
    .reveal.is-in { opacity: 1; transform: none; }

    /* ============================================================
       ✿ CALQUE DÉCOR PLEINE PAGE — fleurs rétro + soleils dessinés-main ✿
       ============================================================ */
    .deco-layer {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 3;
      overflow: hidden;
    }
    .deco-item {
      position: absolute;
      pointer-events: auto;
      touch-action: none;
      user-select: none;
      -webkit-user-select: none;
      cursor: grab;
      will-change: transform;
      filter: drop-shadow(0 6px 14px rgba(248, 116, 47, 0.12));
      transform: translate(var(--dx, 0px), var(--dy, 0px)) rotate(var(--rot, 0deg)) scale(var(--s, 1));
    }
    .deco-item.is-grabbing { cursor: grabbing; z-index: 99; filter: drop-shadow(0 10px 22px rgba(248, 116, 47, 0.22)); }
    .deco-item svg { display: block; width: 100%; height: 100%; overflow: visible; pointer-events: none; }
    .deco-item { width: 74px; height: 74px; }

    @keyframes decoFloat {
      0%   { transform: translate(var(--dx,0px), var(--dy,0px)) rotate(var(--rot,0deg)) scale(var(--s,1)); }
      50%  { transform: translate(var(--dx,0px), calc(var(--dy,0px) - 8px)) rotate(calc(var(--rot,0deg) + 2.5deg)) scale(var(--s,1)); }
      100% { transform: translate(var(--dx,0px), var(--dy,0px)) rotate(var(--rot,0deg)) scale(var(--s,1)); }
    }
    .deco-item.is-float { animation: decoFloat var(--dur, 8s) ease-in-out infinite; animation-delay: var(--delay, 0s); }
    .deco-item.is-grabbing, .deco-item.is-moved { animation: none; }

    /* ============ RESPONSIVE ============ */
    /* sur tout petit écran (téléphone), on autorise le retour à la ligne plutôt que de rogner */
    @media (max-width: 600px) {
      /* Onglets de catégories : ils passent à la ligne, plus grands et plus lisibles au doigt */
      .tabs { flex-wrap: wrap; gap: 0.5rem; }
      .tab { font-size: clamp(0.82rem, 3.4vw, 0.94rem); padding: 0.66em 1.05em; }
    }

    @media (max-width: 760px) {
      .page { padding-bottom: clamp(4.5rem, 12vw, 6rem); }

      .deco-item { width: 58px; height: 58px; filter: drop-shadow(0 4px 9px rgba(248, 116, 47, 0.12)); }
      .deco-item.hide-mobile { display: none; }
    }

    @media (max-width: 480px) {
      .deco-item { width: 50px; height: 50px; }
      .deco-item.hide-small { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      .deco-item.is-float { animation: none !important; }
      .panel.is-shown { animation: none !important; }
    }
  </style>

  <!-- ===================== ONGLETS PAR CATÉGORIE (une seule catégorie visible) ===================== -->
  <script is:inline>
  (function () {
    var tabs = Array.prototype.slice.call(document.querySelectorAll(".tab"));
    if (!tabs.length) return;

    // chaque onglet est relié à SON contenu via aria-controls (indépendant de l'ordre d'affichage)
    function panelOf(tab) { return document.getElementById(tab.getAttribute("aria-controls")); }

    function activate(idx, focusPanel) {
      tabs.forEach(function (t, i) {
        var on = i === idx;
        t.setAttribute("aria-selected", on ? "true" : "false");
        t.tabIndex = on ? 0 : -1;
        var p = panelOf(t);
        if (!p) return;
        if (on) {
          p.hidden = false;
          // forcer un reflow pour rejouer l'animation d'apparition
          p.classList.remove("is-shown");
          void p.offsetWidth;
          p.classList.add("is-shown");
        } else {
          p.classList.remove("is-shown");
          p.hidden = true;
        }
      });
      if (focusPanel) {
        var ap = panelOf(tabs[idx]);
        if (ap) { try { ap.focus({ preventScroll: true }); } catch (e) {} }
      }
    }

    tabs.forEach(function (tab, i) {
      tab.addEventListener("click", function () { activate(i, false); });
      tab.addEventListener("keydown", function (e) {
        var dir = 0;
        if (e.key === "ArrowRight" || e.key === "ArrowDown") dir = 1;
        else if (e.key === "ArrowLeft" || e.key === "ArrowUp") dir = -1;
        else if (e.key === "Home") { e.preventDefault(); activate(0, false); tabs[0].focus(); return; }
        else if (e.key === "End") { e.preventDefault(); activate(tabs.length - 1, false); tabs[tabs.length - 1].focus(); return; }
        if (dir !== 0) {
          e.preventDefault();
          var next = (i + dir + tabs.length) % tabs.length;
          activate(next, false);
          tabs[next].focus();
        }
      });
    });
  })();
  </script>

  <!-- ===================== ACCORDÉONS (ouvrir / fermer une réponse) ===================== -->
  <script is:inline>
  (function () {
    var btns = Array.prototype.slice.call(document.querySelectorAll(".qa__btn"));
    btns.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var qa = btn.closest(".qa");
        var open = qa.classList.toggle("is-open");
        btn.setAttribute("aria-expanded", open ? "true" : "false");
      });
    });
  })();
  </script>

  <!-- ===================== DÉCORS DÉPLAÇABLES À LA SOURIS / AU DOIGT (+ mémoire des positions) ===================== -->
  <script is:inline>
  (function () {
    var STORE_KEY = "soleia-deco-pos-faq";
    var items = Array.prototype.slice.call(document.querySelectorAll(".deco-item"));
    if (!items.length) return;

    var layer = document.querySelector(".deco-layer");
    function sizeLayer() {
      if (!layer) return;
      layer.style.height = "0px";
      layer.style.height = document.documentElement.scrollHeight + "px";
    }
    sizeLayer();
    window.addEventListener("load", sizeLayer);
    window.addEventListener("resize", sizeLayer);
    setTimeout(sizeLayer, 600);
    setTimeout(sizeLayer, 1600);
    if (document.fonts && document.fonts.ready) { document.fonts.ready.then(sizeLayer); }

    function loadPos() {
      try {
        var raw = window.localStorage.getItem(STORE_KEY);
        return raw ? (JSON.parse(raw) || {}) : {};
      } catch (e) { return {}; }
    }
    function savePos(map) {
      try { window.localStorage.setItem(STORE_KEY, JSON.stringify(map)); } catch (e) {}
    }

    var positions = loadPos();

    items.forEach(function (el) {
      var id = el.getAttribute("data-deco-id");
      var p = id && positions[id];
      if (p && (p.dx || p.dy)) {
        el.style.setProperty("--dx", p.dx + "px");
        el.style.setProperty("--dy", p.dy + "px");
        el.classList.add("is-moved");
      }
    });

    var startX = 0, startY = 0;
    var baseDx = 0, baseDy = 0;
    var movedThisDrag = false;
    var current = null;

    function numVar(el, name) {
      var n = parseFloat(el.style.getPropertyValue(name));
      return isNaN(n) ? 0 : n;
    }

    function onDown(e) {
      var el = e.currentTarget;
      current = el;
      movedThisDrag = false;
      baseDx = numVar(el, "--dx");
      baseDy = numVar(el, "--dy");
      startX = e.clientX;
      startY = e.clientY;
      el.classList.add("is-grabbing");
      el.classList.add("is-moved");
      try { el.setPointerCapture(e.pointerId); } catch (err) {}
    }

    function onMove(e) {
      var el = e.currentTarget;
      if (current !== el) return;
      var dx = baseDx + (e.clientX - startX);
      var dy = baseDy + (e.clientY - startY);
      if (Math.abs(e.clientX - startX) > 2 || Math.abs(e.clientY - startY) > 2) movedThisDrag = true;
      el.style.setProperty("--dx", dx + "px");
      el.style.setProperty("--dy", dy + "px");
    }

    function onUp(e) {
      var el = e.currentTarget;
      if (current !== el) return;
      el.classList.remove("is-grabbing");
      try { el.releasePointerCapture(e.pointerId); } catch (err) {}
      if (movedThisDrag) {
        var id = el.getAttribute("data-deco-id");
        if (id) {
          positions[id] = { dx: Math.round(numVar(el, "--dx")), dy: Math.round(numVar(el, "--dy")) };
          savePos(positions);
        }
      }
      current = null;
    }

    items.forEach(function (el) {
      el.addEventListener("pointerdown", onDown);
      el.addEventListener("pointermove", onMove);
      el.addEventListener("pointerup", onUp);
      el.addEventListener("pointercancel", onUp);
      el.addEventListener("dragstart", function (ev) { ev.preventDefault(); });
    });
  })();
  </script>
